DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=meu_app
JWT_SECRET=uma-chave-secreta-longa-e-aleatoria-aqui
PORT=3000
NODE_ENV=development

#NODE_ENV=development em dev, production em prod.
#isso muda comportamento dos cookies principalmente
# secure: true só funciona em produção, secure: false funciona em dev. 
#Se tiver secure: true no dev, o cookie não é enviado e não funciona login.

#A senha aqui precisa ser **a mesma** do `.env` da raiz — porque é o mesmo banco.
#Conecta no MySQL com essa senha - Node.js lê isso
#Esse .env so funciona se rodar o node server.js.
